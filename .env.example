# ── AI provider settings ──────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Any OpenAI-compatible endpoint is supported.

# Endpoint
# Groq       : https://api.groq.com/openai/v1/chat/completions  ← recommended (free, fast)
# OpenRouter : https://openrouter.ai/api/v1/chat/completions
# Ollama     : http://localhost:11434/v1/chat/completions
AI_API_URL=https://api.groq.com/openai/v1/chat/completions

# API key
# Groq       : create a free key at https://console.groq.com
# OpenRouter : create a free key at https://openrouter.ai
# Ollama     : any non-empty string works (e.g. "ollama")
AI_API_KEY=your-key-here

# Model identifier
#
# Groq free models (non-reasoning — fast, reliable JSON output):
#   llama-3.1-8b-instant          — fastest, great for real-time use  ← recommended
#   llama-3.3-70b-versatile       — smarter moves, slightly slower
#   meta-llama/llama-4-maverick-17b-128e-instruct  — newest, multimodal
#
# ⚠️  AVOID reasoning models (deepseek-r1, openai/gpt-oss-*, qwen3, etc.)
#     They spin in infinite thought loops on game prompts.
#
# OpenRouter free-tier picks:
#   meta-llama/llama-3.2-3b-instruct:free
#   qwen/qwen-2.5-7b-instruct:free
#
# Ollama local models:
#   qwen2.5:3b    — best JSON compliance
#   llama3.2      — good balance of speed and quality
#
AI_MODEL=llama-3.1-8b-instant
