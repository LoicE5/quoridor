# ── AI provider settings ──────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Any OpenAI-compatible endpoint is supported.

# Endpoint
# OpenRouter : https://openrouter.ai/api/v1/chat/completions
# Ollama     : http://localhost:11434/v1/chat/completions
AI_API_URL=https://openrouter.ai/api/v1/chat/completions

# API key
# OpenRouter : create a free key at https://openrouter.ai
# Ollama     : any non-empty string works (e.g. "ollama")
AI_API_KEY=your-key-here

# Model identifier
#
# OpenRouter free-tier picks (good reasoning, no cost):
#   meta-llama/llama-3.2-3b-instruct:free   (fast, small)
#   google/gemma-2-9b-it:free               (larger, better reasoning)
#   qwen/qwen-2.5-7b-instruct:free          (strong structured output)
#
# Ollama local models (recommended for M1 Mac, fits in unified memory):
#   qwen2.5:3b    — best structured-JSON compliance, very fast on M1
#   llama3.2      — good balance of speed and quality
#   gemma2:2b     — smallest footprint (~1.6 GB)
#
AI_MODEL=meta-llama/llama-3.2-3b-instruct:free
